# Environment Variables

# Groq API Key for Chatbot
VITE_GROQ_API_KEY=your_groq_api_key_here

# for coming soon notification
VITE_GOOGLE_SCRIPT_URL=your_google_script_url_here

# for contact form
VITE_MCT_CONTACT=your_contact_script_url_here

# Backend API URL (Replace with your actual backend URL)
VITE_API_URL=http://localhost:5000/api

# Razorpay Key ID (Replace with your actual Key ID)
VITE_RAZORPAY_KEY_ID=rzp_test_1234567890
